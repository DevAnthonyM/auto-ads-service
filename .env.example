# ============================================
# Auto-Ads Service — Environment Configuration
# ============================================

# --- Database (PostgreSQL) ---
POSTGRES_USER=postgres
POSTGRES_PASSWORD=changeme
POSTGRES_DB=auto_ads
DATABASE_URL=postgresql+asyncpg://postgres:changeme@db:5432/auto_ads

# --- JWT Authentication ---
JWT_SECRET=your-super-secret-key-change-this-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRATION_MINUTES=60

# --- Default Admin Account ---
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123

# --- Scraper Configuration ---
SCRAPE_INTERVAL_MINUTES=30
SCRAPE_MAX_PAGES=5

# --- Telegram Bot ---
# Create a bot via @BotFather on Telegram to get your token
TELEGRAM_BOT_TOKEN=your-telegram-bot-token

# --- LLM (Anthropic Claude API) ---
# Get your key at https://console.anthropic.com
# If not provided, bot falls back to keyword-based search
ANTHROPIC_API_KEY=your-anthropic-api-key
